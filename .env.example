# SPC website — environment variables
# Copy to .env.local and fill in. NEVER commit real values.
# Everything here is server-side only. Do NOT prefix any of these with NEXT_PUBLIC_.

# --- HubSpot (direct REST API) ---
HUBSPOT_PRIVATE_APP_TOKEN=
# Portal 244173183. Scopes needed: crm.objects.contacts read/write (+ tasks).

# --- Skimmer (via Make.com webhook) ---
MAKE_SKIMMER_WEBHOOK_URL=
# Make scenario that talks to Skimmer. Confirm with Kevin.

# --- Google Drive (service account) ---
GOOGLE_SERVICE_ACCOUNT_JSON=
GDRIVE_ASSESSMENT_FOLDER_ID=
# Service account JSON (stringified) + target folder for assessment PDFs.

# --- Claude API (report wording: notes polish + summary paragraph) ---
ANTHROPIC_API_KEY=
# Server-side only. Used to rewrite the customer-facing WORDING of the report
# (never the findings). If absent, the report falls back to raw notes and omits
# the summary — it never blocks.

# --- Analytics (client-safe, added in content phase) ---
# NEXT_PUBLIC_GA4_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
